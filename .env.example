# Database Configuration
POSTGRES_USER=stockstatus
POSTGRES_PASSWORD=dev123
POSTGRES_DB=stockstatus
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Spring Boot Backend Configuration
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
SPRING_DATASOURCE_USERNAME=${POSTGRES_USER}
SPRING_DATASOURCE_PASSWORD=${POSTGRES_PASSWORD}

# JPA/Hibernate
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false

# Application Settings
APP_BASE_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:80

# Session & Security
SESSION_SECRET=changeme_random_secret_key_min_32_chars

# File Upload
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_STOCKSTATUS=DEBUG

# Redis Cache (optional)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_ENABLED=false

# Backup Configuration
BACKUP_CRON=0 2 * * *
BACKUP_RETENTION_DAYS=14
BACKUP_ENCRYPTION_KEY=changeme_gpg_key_for_backups

# Monitoring & Alerting (optional)
ALERT_EMAIL=admin@example.com
ALERT_THRESHOLD_NET_WORTH=1000000

# Frontend Configuration
ANGULAR_API_URL=http://localhost:8080/api

# Production Settings (for docker-compose.prod.yml)
DOMAIN=stockstatus.example.com
ACME_EMAIL=admin@example.com
